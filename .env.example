# Groq API Key from https://console.groq.com/
GROQ_API_KEY=gsk_your-key-here

# Groq model (llama-3.3-70b-versatile recommended for best function calling)
GROQ_MODEL=llama-3.3-70b-versatile

# Backend microservice URLs
USER_SERVICE_URL=http://localhost:8081
CLINIC_SERVICE_URL=http://localhost:8082
QUEUE_SERVICE_URL=http://localhost:8085
CONSULTATION_SERVICE_URL=http://localhost:8086
MEDICAL_RECORDS_SERVICE_URL=http://localhost:8087

# Chatbot server port
CHATBOT_PORT=8090
